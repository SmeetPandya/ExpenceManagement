<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    tools:context=".Reminder">

    <LinearLayout
        android:id="@+id/headerZone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:id="@+id/analyticsLogo"
            android:layout_width="48dp"
            android:layout_height="48dp"
            app:srcCompat="@drawable/logo" />

        <TextView
            android:id="@+id/analyticsTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Scheduled Payments"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/summaryCardLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        app:cardBackgroundColor="@color/bg_card"
        app:cardCornerRadius="24dp"
        app:cardElevation="8dp"
        app:layout_constraintTop_toBottomOf="@id/headerZone">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvTotalBillsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Bills This Month"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvTotalBillsAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹12,400"
                android:textColor="@color/brand_primary"
                android:textSize="36sp"
                android:textStyle="bold"
                android:layout_marginTop="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvTotalBillsTitle" />

            <View
                android:id="@+id/dividerLine"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/brand_primary"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvTotalBillsAmount" />

            <TextView
                android:id="@+id/tvRemainingTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total to Pay (Including Overdue)"
                android:textColor="@color/brand_primary"
                android:textSize="14sp"
                android:layout_marginTop="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/dividerLine" />

            <TextView
                android:id="@+id/tvRemainingAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹4,200"
                android:textColor="@color/money_income"
                android:textSize="20sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/tvRemainingTitle"
                app:layout_constraintBottom_toBottomOf="@id/tvRemainingTitle" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/listTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        android:text="Upcoming Bills"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        app:layout_constraintTop_toBottomOf="@id/summaryCardLayout" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/billsRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        tools:listitem="@layout/item_scheduled_bill"
        app:layout_constraintTop_toBottomOf="@id/listTitle"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView" />

    <TextView
        android:id="@+id/emptyStateBills"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="No scheduled payments."
        android:textAlignment="center"
        android:textColor="@color/text_secondary"
        android:textSize="18sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@+id/billsRecyclerView"
        app:layout_constraintBottom_toBottomOf="@+id/billsRecyclerView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigationView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_card"
        app:elevation="16dp"
        app:labelVisibilityMode="selected"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@color/bottom_nav_selector"
        app:itemTextColor="@color/bottom_nav_selector"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddExpense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        app:srcCompat="@drawable/ic_add"
        app:tint="@color/bg_main"
        app:backgroundTint="@color/brand_primary"
        android:elevation="12dp"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigationView"
        app:layout_constraintEnd_toEndOf="parent"
        tools:ignore="ContentDescription" />

</androidx.constraintlayout.widget.ConstraintLayout>